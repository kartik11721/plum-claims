# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Provider: use ONE of the two blocks below ────────────────────────────────

# Option A: Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Option B: Azure OpenAI (leave Option A blank if using this)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_RESOURCE_NAME=
AZURE_DEPLOYMENT_LLM=

# ── Model ────────────────────────────────────────────────────────────────────
# Claude model to use (Anthropic provider only)
CLAUDE_MODEL=claude-sonnet-4-6

# ── Storage ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./claims.db
UPLOAD_DIR=/tmp/plum_uploads

# ── Other ────────────────────────────────────────────────────────────────────
POLICY_FILE=../policy_terms.json
